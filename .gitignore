# =============================================================================
# fpwiki .gitignore
# Nuxt 4 + @nuxt/content v3 + Nuxt UI v4 + pnpm + Vitest + Husky + Firebase App Hosting
# Each section explains *why* — please keep that habit if you add entries.
#
# IMPORTANT: gitignore does NOT support inline comments. Trailing `#` on a
# pattern line is treated as part of the pattern. Always put comments on
# their own line.
# =============================================================================

# -----------------------------------------------------------------------------
# Nuxt build artifacts (regenerated on `pnpm dev` / `pnpm build`)
# `.nuxtrc` is auto-rewritten by `nuxt prepare`; never track it.
# `.data/` is @nuxt/content v3's SQLite cache.
# -----------------------------------------------------------------------------
.nuxt
.nuxtrc
.output
.data
dist
.vercel_build_output
.netlify

# -----------------------------------------------------------------------------
# Node / pnpm
# -----------------------------------------------------------------------------
node_modules
.npm
.pnpm
.pnpm-store
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/cache
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Husky internals — managed by `husky install` / `pnpm prepare`.
# Track our own hook scripts (.husky/pre-commit, etc.); ignore the auto-
# generated stub directory husky injects into.
# -----------------------------------------------------------------------------
.husky/_

# -----------------------------------------------------------------------------
# Test + coverage
# -----------------------------------------------------------------------------
coverage
.nyc_output
.vitest
*.lcov
playwright-report
playwright/.cache
test-results

# -----------------------------------------------------------------------------
# Build / cache artifacts
# -----------------------------------------------------------------------------
*.tsbuildinfo
.cache
.parcel-cache
.turbo
.eslintcache

# -----------------------------------------------------------------------------
# Browser-automation / dev-time UX-review artifacts.
# Generated by Playwright MCP and ad-hoc screenshot scripts. Never useful in
# git history; revisit if a CI visual-regression flow is added later.
# -----------------------------------------------------------------------------
.playwright-mcp
qc-*.png
*-screenshot.png

# -----------------------------------------------------------------------------
# Environment / secrets.
# `.env.example` and `.env.sample` are allowed as templates.
# Firebase secrets live in Cloud Secret Manager — never commit them here.
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12
service-account*.json
credentials*.json
.runtimeconfig.json

# -----------------------------------------------------------------------------
# Firebase CLI artifacts
# -----------------------------------------------------------------------------
.firebase
firebase-debug.log*
firebase-debug.*.log*

# -----------------------------------------------------------------------------
# IDE / editor scratch.
# `.vscode/` is intentionally NOT ignored — `extensions.json` and
# `settings.json` are team-shared. Put user-only files in .git/info/exclude.
# -----------------------------------------------------------------------------
.idea
.fleet
.history
*.code-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Misc local scratch
# -----------------------------------------------------------------------------
*.log
*.bak
*.tmp
*.orig
tmp/
