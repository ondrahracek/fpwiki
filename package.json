{
  "name": "fpwiki",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Czech-language read-only wiki for students of Fakulta podnikatelská VUT v Brně.",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "nuxt dev",
    "predev": "tsx scripts/fetch-content.ts",
    "build": "nuxt build",
    "prebuild": "tsx scripts/fetch-content.ts",
    "preview": "nuxt preview",
    "prepreview": "tsx scripts/fetch-content.ts",
    "generate": "nuxt generate",
    "pregenerate": "tsx scripts/fetch-content.ts",
    "postinstall": "tsx scripts/fetch-content.ts && nuxt prepare",
    "fetch-content": "tsx scripts/fetch-content.ts",
    "content:refresh": "tsx scripts/fetch-content.ts --force",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "nuxt prepare && vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "content:validate": "tsx scripts/validate-content.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@flowershow/remark-wiki-link": "^3.4.0",
    "@nuxt/content": "^3.7.1",
    "@nuxt/ui": "^4.0.1",
    "better-sqlite3": "^12.5.0",
    "fuse.js": "^7.1.0",
    "katex": "^0.16.22",
    "minisearch": "^7.2.0",
    "nuxt": "^4.1.3",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.1.16",
    "vue": "^3.5.27",
    "vue-router": "^4.5.1",
    "zod": "^3.25.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@nuxt/eslint": "^1.10.0",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/test-utils": "^3.18.0",
    "@types/node": "^22.18.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.0",
    "happy-dom": "^15.11.7",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tar": "^7.5.13",
    "tsx": "^4.20.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.0"
  }
}
